# Required
DEPLOYER_PK=0xYOUR_PRIVATE_KEY

# Target network: sepolia | mainnet
UNICHAIN_NETWORK=sepolia

# Optional override (default: official Unichain RPC by network)
# RPC_URL=https://sepolia.unichain.org

# Optional issuers (default: deployer address)
# WORLD_ISSUER=0x...
# SELF_ISSUER=0x...
# INITIAL_HOOK_CALLER=0x...

# Optional adapter IDs / pool
# WORLD_ADAPTER_ID=0x...
# SELF_ADAPTER_ID=0x...
# POOL_ID=0x...

# Optional policy config
# WORLD_REQUIRE_HUMAN=true
# POLICY_MIN_AGE=18
# POLICY_REQUIRE_CONTRIBUTOR=true
# POLICY_REQUIRE_DAO_MEMBER=false
# POLICY_START_TIME=0
# POLICY_END_TIME=0
# POLICY_ACTIVE=true
