# Choose: unichain-sepolia | unichain-mainnet | custom
VITE_DEFAULT_NETWORK=unichain-sepolia

# Used when VITE_DEFAULT_NETWORK=custom
VITE_RPC_URL=http://127.0.0.1:8545
VITE_CHAIN_ID=31337

# Official Unichain RPC defaults (override only if needed)
VITE_UNICHAIN_MAINNET_RPC_URL=https://mainnet.unichain.org
VITE_UNICHAIN_SEPOLIA_RPC_URL=https://sepolia.unichain.org

# --- Unichain Mainnet deployment values ---
VITE_UNICHAIN_MAINNET_POLICY_ENGINE_ADDRESS=
VITE_UNICHAIN_MAINNET_HOOK_ADDRESS=
VITE_UNICHAIN_MAINNET_POLICY_ID=1
VITE_UNICHAIN_MAINNET_POOL_ID=
VITE_UNICHAIN_MAINNET_EPOCH=1
VITE_UNICHAIN_MAINNET_AUTOMATION_MODULE_ADDRESS=
VITE_UNICHAIN_MAINNET_USER_ADDRESS=
VITE_UNICHAIN_MAINNET_WORLD_ADAPTER_ID=
VITE_UNICHAIN_MAINNET_SELF_ADAPTER_ID=
# Optional: fetch defaults from a deployment artifact URL/path
# For local Vite dev with absolute path use /@fs/<abs-path>
VITE_UNICHAIN_MAINNET_DEPLOYMENT_ARTIFACT=

# --- Unichain Sepolia deployment values ---
VITE_UNICHAIN_SEPOLIA_POLICY_ENGINE_ADDRESS=
VITE_UNICHAIN_SEPOLIA_HOOK_ADDRESS=
VITE_UNICHAIN_SEPOLIA_POLICY_ID=1
VITE_UNICHAIN_SEPOLIA_POOL_ID=
VITE_UNICHAIN_SEPOLIA_EPOCH=1
VITE_UNICHAIN_SEPOLIA_AUTOMATION_MODULE_ADDRESS=
VITE_UNICHAIN_SEPOLIA_USER_ADDRESS=
VITE_UNICHAIN_SEPOLIA_WORLD_ADAPTER_ID=
VITE_UNICHAIN_SEPOLIA_SELF_ADAPTER_ID=
# Optional: fetch defaults from a deployment artifact URL/path
# For local Vite dev with absolute path use /@fs/<abs-path>
VITE_UNICHAIN_SEPOLIA_DEPLOYMENT_ARTIFACT=

# Optional proof defaults for quick testing
VITE_WORLD_ADAPTER_ID=
VITE_WORLD_PROOF_PAYLOAD=0x
VITE_SELF_ADAPTER_ID=
VITE_SELF_PROOF_PAYLOAD=0x
VITE_NULLIFIER=0x1111111111111111111111111111111111111111111111111111111111111111
